@inherits LayoutComponentBase
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop

@inject NavigationManager Nav
@inject IJSRuntime Js

<link href="/css/site.css" rel="stylesheet" />

<div class="site-header">
    <div class="brand">eBusiness</div>
    <nav class="top-nav @( _menuOpen ? "open" : "" )" aria-hidden="@(!_menuOpen)">
        <NavLink href="/" class="nav-item" Match="NavLinkMatch.All" @onclick="CloseMenu">Home</NavLink>
        <NavLink href="/about" class="nav-item" @onclick="CloseMenu">About</NavLink>
        <AuthorizeView>
            <Authorized>
                <NavLink href="/settings" class="nav-item" @onclick="CloseMenu">Instellingen</NavLink>
            </Authorized>
        </AuthorizeView>
        <NavLink href="/services" class="nav-item" @onclick="CloseMenu">Services</NavLink>
        <NavLink href="/portfolio" class="nav-item" @onclick="CloseMenu">Portfolio</NavLink>
        <NavLink href="/team" class="nav-item" @onclick="CloseMenu">Team</NavLink>
        <NavLink href="/contact" class="nav-item" @onclick="CloseMenu">Contact</NavLink>
        <button class="btn-getstarted" @onclick="CloseMenu">Get Started</button>
    </nav>
    <button class="nav-toggle @( _menuOpen ? "open" : "" )" @onclick="ToggleMenu" aria-label="Toggle navigation" aria-expanded="@(_menuOpen ? "true" : "false")">
        <span></span>
        <span></span>
        <span></span>
    </button>
    <div class="auth-area">
        <AuthorizeView>
            <Authorized Context="authState">
                <div class="user-info">Ingelogd als @GetDisplayName(authState)</div>
                <button class="btn-logout" @onclick="Logout" disabled="@_logoutBusy">@(_logoutBusy ? "Uitloggen..." : "Uitloggen")</button>
            </Authorized>
            <NotAuthorized>
                <a class="btn-login" href="login">Inloggen</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<main>
    <article class="content">
        @Body
    </article>
</main>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private IJSObjectReference? _authModule;
    private bool _logoutBusy;
    private string? _logoutError;
    private bool _menuOpen;

    /// <summary>
    /// Imports the shared auth JavaScript helper so the layout can trigger logout via fetch.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _authModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/authClient.js");
        }
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void CloseMenu()
    {
        _menuOpen = false;
    }

    /// <summary>
    /// Returns the display name shown in the header, defaulting to "Owner" if none is present.
    /// </summary>
    private string GetDisplayName(AuthenticationState authState)
    {
        return authState.User.Identity?.Name ?? "Owner";
    }

    /// <summary>
    /// Calls the logout endpoint via the JS module so the cookie gets cleared in the browser context, then navigates to login.
    /// </summary>
    private async Task Logout()
    {
        if (_authModule is null)
        {
            _logoutError = "Actie mislukt. Probeer opnieuw.";
            return;
        }

        try
        {
            _logoutBusy = true;
            _logoutError = null;
            var result = await _authModule.InvokeAsync<FetchResult>("postJson", "/auth/logout", new { });
            if (result.Ok)
            {
                Nav.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                _logoutError = "Uitloggen mislukt.";
            }
        }
        catch (JSException ex)
        {
            _logoutError = $"Uitloggen mislukt: {ex.Message}";
        }
        finally
        {
            _logoutBusy = false;
        }
    }

    /// <summary>
    /// Disposes the imported JS module for cleanliness.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        if (_authModule is not null)
        {
            await _authModule.DisposeAsync();
        }
    }

    private sealed class FetchResult
    {
        public bool Ok { get; set; }
        public int Status { get; set; }
        public string? Body { get; set; }
    }
}
