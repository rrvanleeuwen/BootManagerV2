@inherits LayoutComponentBase
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Routing

@inject NavigationManager Nav
@inject IJSRuntime Js

<!-- SB Admin 2 theme and FontAwesome -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/css/sb-admin-2.min.css" rel="stylesheet" />
<link href="/css/site.css" rel="stylesheet" />

<div class="navbar navbar-expand-lg navbar-light bg-white topbar mb-4 static-top shadow site-header">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">BootManager</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#topNavbarSupportedContent" aria-controls="topNavbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="fa fa-bars"></span>
        </button>

        <NavMenu />

        <ul class="navbar-nav ml-auto">
            <AuthorizeView>
                <Authorized>
                    <li class="nav-item">
                        <button class="btn btn-link nav-link" @onclick="Logout" disabled="@_logoutBusy" title="Uitloggen">
                            <i class="fas fa-sign-out-alt"></i>
                            <span class="d-none d-lg-inline"> Uitloggen</span>
                        </button>
                    </li>
                </Authorized>
            </AuthorizeView>
            <li class="nav-item dropdown no-arrow">
                <AuthorizeView>
                    <Authorized Context="authState">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="mr-2 d-none d-lg-inline text-gray-600 small">Ingelogd als @GetDisplayName(authState)</span>
                            <i class="fas fa-user-circle fa-lg"></i>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in" aria-labelledby="userDropdown">
                            <a class="dropdown-item" href="/settings">Instellingen</a>
                            <div class="dropdown-divider"></div>
                            <button class="dropdown-item" @onclick="Logout" disabled="@_logoutBusy">@(_logoutBusy ? "Uitloggen..." : "Uitloggen")</button>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a class="nav-link" href="/login">Inloggen</a>
                    </NotAuthorized>
                </AuthorizeView>
            </li>
        </ul>
    </div>
</div>

<div class="container-fluid">
    <main>
        <article class="content p-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

<!-- SB Admin 2 scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/js/sb-admin-2.min.js"></script>
<script src="/js/ui.js"></script>

@code {
    private IJSObjectReference? _authModule;
    private bool _logoutBusy;
    private string? _logoutError;
    private bool _menuOpen;

    /// <summary>
    /// Imports the shared auth JavaScript helper so the layout can trigger logout via fetch.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _authModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/authClient.js");
            // Setup auto-collapse for mobile menu so clicking outside or on items closes it
            await Js.InvokeVoidAsync("setupAutoCollapse", "topNavbarSupportedContent", null);
        }
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void CloseMenu()
    {
        _menuOpen = false;
    }

    /// <summary>
    /// Returns the display name shown in the header, defaulting to "Owner" if none is present.
    /// </summary>
    private string GetDisplayName(AuthenticationState authState)
    {
        return authState.User.Identity?.Name ?? "Owner";
    }

    /// <summary>
    /// Calls the logout endpoint via the JS module so the cookie gets cleared in the browser context, then navigates to login.
    /// </summary>
    private async Task Logout()
    {
        if (_authModule is null)
        {
            _logoutError = "Actie mislukt. Probeer opnieuw.";
            return;
        }

        try
        {
            _logoutBusy = true;
            _logoutError = null;
            var result = await _authModule.InvokeAsync<FetchResult>("postJson", "/auth/logout", new { });
            if (result.Ok)
            {
                Nav.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                _logoutError = "Uitloggen mislukt.";
            }
        }
        catch (JSException ex)
        {
            _logoutError = $"Uitloggen mislukt: {ex.Message}";
        }
        finally
        {
            _logoutBusy = false;
        }
    }

    /// <summary>
    /// Disposes the imported JS module for cleanliness.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        if (_authModule is not null)
        {
            await _authModule.DisposeAsync();
        }
    }

    private sealed class FetchResult
    {
        public bool Ok { get; set; }
        public int Status { get; set; }
        public string? Body { get; set; }
    }
}
